#!/bin/sh
# Compatibility entry point for installations created before jd-booking.
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
printf '%s\n' 'jd-schedule has been renamed to jd-booking; compatibility mode is active.' >&2
export JD_BOOKING_LEGACY_MODE=1
exec "$SCRIPT_DIR/jd-booking" "$@"
